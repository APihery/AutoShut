<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AutoShut"
             xmlns:converters="clr-namespace:AutoShut.Converters"
             x:Class="AutoShut.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <converters:StatusToStringConverter x:Key="StatusToStringConverter" />
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:PercentageToProgressConverter x:Key="PercentageToProgressConverter" />
            <converters:RenderTypeToIndexConverter x:Key="RenderTypeToIndexConverter" />
            <converters:StatusToRetryVisibleConverter x:Key="StatusToRetryVisibleConverter" />
            <converters:StatusToProcessingConverter x:Key="StatusToProcessingConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:OutputPathDisplayConverter x:Key="OutputPathDisplayConverter" />
            <converters:FilePathTruncateConverter x:Key="FilePathTruncateConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
