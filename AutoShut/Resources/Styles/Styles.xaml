    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="#0F172A" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="#1f1f1f" />
        <Setter Property="Shell.ForegroundColor" Value="#9880e5" />
        <Setter Property="Shell.TitleColor" Value="#9880e5" />
        <Setter Property="Shell.DisabledColor" Value="#141414" />
        <Setter Property="Shell.UnselectedColor" Value="#C8C8C8" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="Black" />
        <Setter Property="Shell.TabBarForegroundColor" Value="White" />
        <Setter Property="Shell.TabBarTitleColor" Value="White" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="#C8C8C8" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="#1f1f1f" />
        <Setter Property="BarTextColor" Value="White" />
        <Setter Property="IconColor" Value="White" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="#141414" />
        <Setter Property="BarTextColor" Value="White" />
        <Setter Property="UnselectedTabColor" Value="#141414" />
        <Setter Property="SelectedTabColor" Value="#C8C8C8" />
    </Style>

</ResourceDictionary>
